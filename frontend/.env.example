# Frontend API base URL.
# - Same-origin proxy setup: /api
# - Separate frontend/backend domains: https://your-backend-domain/api
VITE_API_BASE_URL=/api

# W9 (Service Gap Detector) synthetic QA mode.
# Values: auto | off | force
# - auto: show synthetic bars only when aligned AI rows are empty
# - off: never show synthetic bars
# - force: always show synthetic bars
VITE_W9_SYNTHETIC_MODE=auto

# Internal debug only: allow old deterministic W9 rows when AI/synthetic rows are absent.
VITE_W9_ENABLE_LEGACY_DEBUG=false
