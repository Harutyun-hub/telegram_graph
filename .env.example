# Telegram
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_PHONE=+10000000000
# Local development session file name. Keep it different from production usage.
TELEGRAM_SESSION_NAME=telegram_scraper_dev
# For Railway/cloud deployment only (generate locally with scripts/export_telegram_session.py)
# TELEGRAM_SESSION_STRING=your_base64_session_string

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SOCIAL_SUPABASE_URL=https://your-social-project.supabase.co
SOCIAL_SUPABASE_SERVICE_ROLE_KEY=your_social_supabase_service_role_key

# Neo4j
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j
SOCIAL_NEO4J_URI=neo4j+s://your-social-instance.databases.neo4j.io
SOCIAL_NEO4J_USERNAME=neo4j
SOCIAL_NEO4J_PASSWORD=your_social_neo4j_password
SOCIAL_NEO4J_DATABASE=neo4j

# OpenAI
OpenAI_API=sk-your-openai-api-key
OPENAI_MODEL=gpt-5-nano
SCRAPECREATORS_API_KEY=your_scrapecreators_api_key

# Runtime
APP_HOST=0.0.0.0
APP_PORT=8001
ANALYTICS_API_REQUIRE_AUTH=false
# Generate separate real secrets for frontend proxy and OpenClaw in production.
ANALYTICS_API_KEY_FRONTEND=
ANALYTICS_API_KEY_OPENCLAW=
ANALYTICS_RATE_LIMIT_ENABLED=true
ANALYTICS_RATE_LIMIT_WINDOW_SECONDS=60
ANALYTICS_RATE_LIMIT_MAX_REQUESTS=120
REDIS_URL=redis://localhost:6379/0
ADMIN_API_KEY=
ENABLE_DEBUG_ENDPOINTS=false
APP_ROLE=web
RUN_STARTUP_WARMERS=false
# Staging stays web-only by default. Set true only on a dedicated staging worker
# when you want to run comment/post analysis and scheduled AI jobs for a controlled test.
STAGING_ENABLE_BACKGROUND_JOBS=false

# AI helper / operator auth
# Backend-to-backend OpenClaw Gateway base URL. Do not point the browser at this directly.
OPENCLAW_GATEWAY_BASE_URL=
# Shared-secret token used only by the backend when calling OpenClaw Gateway.
OPENCLAW_GATEWAY_TOKEN=
# Transport mode for the backend OpenClaw client: cli_bridge, openai_compatible, legacy, or auto.
OPENCLAW_GATEWAY_TRANSPORT=cli_bridge
# OpenAI-compatible model name used only for /chat/completions deployments.
OPENCLAW_GATEWAY_MODEL=
# Reuse the same OpenClaw agent id as Telegram/OpenClaw integrations.
OPENCLAW_ANALYTICS_AGENT_ID=
# Private Hostinger bridge URL used by the cli_bridge transport.
OPENCLAW_BRIDGE_BASE_URL=
# Shared secret used by Railway backend to call the Hostinger bridge.
OPENCLAW_BRIDGE_TOKEN=
# MVP bridge agent id. Keep restricted to the proven working web helper agent.
OPENCLAW_BRIDGE_AGENT_ID=web-api-assistant
# Dedicated session for the floating web AI helper.
OPENCLAW_WEB_SESSION_KEY=web-api-assistant-web
# Dedicated session for KB generation. Keep it separate from the web helper session.
OPENCLAW_KB_SESSION_KEY=
OPENCLAW_HELPER_TIMEOUT_SECONDS=30
OPENCLAW_HELPER_CONNECT_TIMEOUT_SECONDS=10
OPENCLAW_HELPER_READ_TIMEOUT_SECONDS=30
OPENCLAW_HELPER_RETRY_ATTEMPTS=1
OPENCLAW_HELPER_HISTORY_MAX_MESSAGES=40
OPENCLAW_HELPER_HISTORY_MAX_CHARS=12000
OPENCLAW_HELPER_REPLAY_MAX_MESSAGES=20
OPENCLAW_HELPER_REPLAY_MAX_CHARS=8000
OPENCLAW_HELPER_TRANSCRIPT_TTL_SECONDS=604800
OPENCLAW_HELPER_HTTP_MAX_BODY_BYTES=8192
AI_HELPER_ADMIN_SUPABASE_USER_ID=
AI_HELPER_ADMIN_EMAIL=

# CORS (comma-separated). Use your frontend domain(s) in production.
# Example: https://your-frontend.up.railway.app
CORS_ALLOW_ORIGINS=*

# Dashboard cache + observability
DASH_CACHE_TTL_SECONDS=900
DASH_STALE_WHILE_REVALIDATE_ENABLED=true
DASH_REFRESH_TIMEOUT_SECONDS=30
DASH_MAX_STALE_SECONDS=1800
DASH_REFRESH_FAILURE_ALERT_THRESHOLD=3
FRESHNESS_CACHE_TTL_SECONDS=300
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# Neo4j driver tuning
NEO4J_MAX_CONNECTION_POOL_SIZE=20
NEO4J_CONNECTION_ACQUISITION_TIMEOUT_SECONDS=10
NEO4J_MAX_TRANSACTION_RETRY_TIME_SECONDS=15
NEO4J_SLOW_QUERY_MS=750

# Optional processing tuning
AI_NORMAL_COMMENT_LIMIT=60
AI_NORMAL_POST_LIMIT=25
AI_NORMAL_SYNC_LIMIT=80
AI_CATCHUP_COMMENT_LIMIT=220
AI_CATCHUP_POST_LIMIT=120
AI_CATCHUP_SYNC_LIMIT=320

# Feature flags
FEATURE_TAXONOMY_V2=true
FEATURE_ENTITY_GRAPH=true
FEATURE_AI_ANALYST=false
FEATURE_AI_PRESENTER=false
FEATURE_QUESTION_BRIEFS_AI=true
FEATURE_BEHAVIORAL_BRIEFS_AI=true
FEATURE_EXTRACTION_V2=true

# AI safety/performance
AI_REQUEST_TIMEOUT_SECONDS=45
AI_REQUEST_MAX_RETRIES=2
AI_REQUEST_RETRY_BACKOFF_SECONDS=1.5
AI_USAGE_TELEMETRY_ENABLED=true
AI_BATCH_SIZE=25
AI_COMMENT_MAX_TOKENS=1200
AI_COMMENT_WORKERS=3
AI_POST_WORKERS=2
AI_MAX_INFLIGHT_REQUESTS=4
AI_FAILURE_MAX_RETRIES=5
AI_FAILURE_BACKOFF_SECONDS=60
AI_FAILURE_BACKOFF_MAX_SECONDS=3600
AI_POST_BATCH_SIZE=5
AI_POST_BATCH_MAX_TOKENS=2600
AI_THREAD_SUMMARY_CONTEXT_MESSAGES=12

# AI question cards (contextual societal asks)
QUESTION_BRIEFS_MODEL=gpt-5-nano
QUESTION_BRIEFS_MAX_TOKENS=2600
QUESTION_BRIEFS_TRIAGE_MODEL=gpt-5-nano
QUESTION_BRIEFS_TRIAGE_MAX_TOKENS=1400
QUESTION_BRIEFS_USE_AI_TRIAGE=false
QUESTION_BRIEFS_SYNTHESIS_MODEL=gpt-5-nano
QUESTION_BRIEFS_SYNTHESIS_MAX_TOKENS=2200
QUESTION_BRIEFS_CACHE_TTL_SECONDS=7200
QUESTION_BRIEFS_WINDOW_DAYS=30
QUESTION_BRIEFS_MAX_TOPICS=14
QUESTION_BRIEFS_MAX_BRIEFS=8
QUESTION_BRIEFS_EVIDENCE_PER_TOPIC=14
QUESTION_BRIEFS_MIN_CONFIDENCE=0.60
QUESTION_BRIEFS_MESSAGE_CHAR_LIMIT=900
QUESTION_BRIEFS_CONTEXT_CHAR_LIMIT=520
QUESTION_BRIEFS_SYNTH_EVIDENCE_LIMIT=8
QUESTION_BRIEFS_CLUSTER_SIMILARITY=0.42
QUESTION_BRIEFS_MIN_CLUSTER_MESSAGES=8
QUESTION_BRIEFS_MIN_CLUSTER_USERS=3
QUESTION_BRIEFS_MIN_CLUSTER_CHANNELS=2
QUESTION_BRIEFS_MAX_CLUSTER_CANDIDATES=24
QUESTION_BRIEFS_MIN_ACCEPTED_CLUSTERS=6
QUESTION_BRIEFS_REFRESH_MINUTES=120
QUESTION_BRIEFS_REFRESH_ON_STARTUP=true
QUESTION_BRIEFS_PROMPT_VERSION=qcards-v2

# Behavioral briefs (AI-generated behavioral insights)
BEHAVIORAL_BRIEFS_MODEL=gpt-5-nano
BEHAVIORAL_BRIEFS_MAX_TOKENS=1500
BEHAVIORAL_BRIEFS_CACHE_TTL_SECONDS=7200
BEHAVIORAL_BRIEFS_WINDOW_DAYS=30
BEHAVIORAL_BRIEFS_MIN_MESSAGES=10
BEHAVIORAL_BRIEFS_MIN_USERS=3
BEHAVIORAL_BRIEFS_MAX_BRIEFS=8
BEHAVIORAL_BRIEFS_REFRESH_MINUTES=120
BEHAVIORAL_BRIEFS_REFRESH_ON_STARTUP=true
BEHAVIORAL_BRIEFS_PROMPT_VERSION=behavior-v2

# ── Knowledge Base (RAG) ──────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com → API Keys → Create
GEMINI_API_KEY=
# Docker volume mount path for ChromaDB vector storage (persists across restarts)
KB_STORAGE_PATH=/data/kb
# Vector dimensions: 768 (fast, default) | 1536 | 3072 (highest accuracy)
KB_EMBED_DIM=768
# Chunks retrieved per query (1–20)
KB_TOP_K=8
# Tokens per document chunk (500–4000)
KB_CHUNK_SIZE=1500
# Overlap tokens between consecutive chunks
KB_CHUNK_OVERLAP=200
# OpenAI model used for answer generation (defaults to OPENAI_MODEL if unset)
KB_GENERATION_MODEL=
# Maximum upload file size in MB
KB_UPLOAD_MAX_MB=50

# Additional processing configuration
AI_MESSAGE_CHAR_LIMIT=800
TAXONOMY_VERSION=v2
STRICT_TAXONOMY_PROMPT=true
SCRAPE_BACKPRESSURE_UNPROCESSED_POSTS=500
SCRAPE_BACKPRESSURE_UNPROCESSED_COMMENTS=2000
GROUP_MAX_MESSAGES_PER_SOURCE_PER_CYCLE=400
GROUP_MAX_THREAD_ANCHORS_PER_SOURCE_PER_CYCLE=120

# Social media activities
SOCIAL_DATABASE_URL=postgresql://postgres.project-ref:password@aws-1-region.pooler.supabase.com:6543/postgres?sslmode=require
SOCIAL_FETCH_MAX_PAGES=3
SOCIAL_FETCH_PAGE_SIZE=50
SOCIAL_ANALYSIS_BATCH_SIZE=8
SOCIAL_ANALYSIS_MODEL=gpt-5.4-mini
SOCIAL_ANALYSIS_PROMPT_VERSION=social-v1
SOCIAL_GRAPH_PROJECTION_VERSION=social-graph-v1
SOCIAL_TIKTOK_ENABLED=false
SOCIAL_RUNTIME_ENABLED=true
SOCIAL_ACTIVITY_RETENTION_DAYS=365
SOCIAL_PAYLOAD_RETENTION_DAYS=90
SOCIAL_STAGE_CLAIM_LIMIT=120
SOCIAL_STAGE_LEASE_SECONDS=900
SOCIAL_RETRY_BASE_SECONDS=120
SOCIAL_RETRY_MAX_SECONDS=3600
