# Telegram
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_PHONE=+10000000000
# Local development session file name. Keep it different from production usage.
TELEGRAM_SESSION_NAME=telegram_scraper_dev
# For Railway/cloud deployment only (generate locally with scripts/export_telegram_session.py)
# TELEGRAM_SESSION_STRING=your_base64_session_string

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Neo4j
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# OpenAI
OpenAI_API=sk-your-openai-api-key
OPENAI_MODEL=gpt-5-nano

# Runtime
APP_HOST=0.0.0.0
APP_PORT=8001
ANALYTICS_API_REQUIRE_AUTH=false
# Generate separate real secrets for frontend proxy and OpenClaw in production.
ANALYTICS_API_KEY_FRONTEND=
ANALYTICS_API_KEY_OPENCLAW=
ANALYTICS_RATE_LIMIT_ENABLED=true
ANALYTICS_RATE_LIMIT_WINDOW_SECONDS=60
ANALYTICS_RATE_LIMIT_MAX_REQUESTS=120
APP_ROLE=web
RUN_STARTUP_WARMERS=false
ENABLE_SCRAPER_SCHEDULER=false
REQUIRE_TELEGRAM_CREDENTIALS=false

# CORS (comma-separated). Use your frontend domain(s) in production.
# Example: https://your-frontend.up.railway.app
CORS_ALLOW_ORIGINS=*

# Dashboard cache + observability
DASH_CACHE_TTL_SECONDS=900
DASH_STALE_WHILE_REVALIDATE_ENABLED=true
DASH_REFRESH_TIMEOUT_SECONDS=30
DASH_MAX_STALE_SECONDS=1800
DASH_REFRESH_FAILURE_ALERT_THRESHOLD=3
FRESHNESS_CACHE_TTL_SECONDS=300
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

# Neo4j driver tuning
NEO4J_MAX_CONNECTION_POOL_SIZE=20
NEO4J_CONNECTION_ACQUISITION_TIMEOUT_SECONDS=10
NEO4J_MAX_TRANSACTION_RETRY_TIME_SECONDS=15
NEO4J_SLOW_QUERY_MS=750

# Optional processing tuning
AI_NORMAL_COMMENT_LIMIT=60
AI_NORMAL_POST_LIMIT=25
AI_NORMAL_SYNC_LIMIT=80
AI_CATCHUP_COMMENT_LIMIT=220
AI_CATCHUP_POST_LIMIT=120
AI_CATCHUP_SYNC_LIMIT=320

# Feature flags
FEATURE_TAXONOMY_V2=true
FEATURE_ENTITY_GRAPH=true
FEATURE_AI_ANALYST=false
FEATURE_AI_PRESENTER=false
FEATURE_QUESTION_BRIEFS_AI=true
FEATURE_BEHAVIORAL_BRIEFS_AI=true
FEATURE_EXTRACTION_V2=true

# AI safety/performance
AI_REQUEST_TIMEOUT_SECONDS=45
AI_REQUEST_MAX_RETRIES=2
AI_REQUEST_RETRY_BACKOFF_SECONDS=1.5
AI_BATCH_SIZE=25
AI_COMMENT_MAX_TOKENS=1200
AI_COMMENT_WORKERS=3
AI_POST_WORKERS=2
AI_MAX_INFLIGHT_REQUESTS=4
AI_FAILURE_MAX_RETRIES=5
AI_FAILURE_BACKOFF_SECONDS=60
AI_FAILURE_BACKOFF_MAX_SECONDS=3600
AI_POST_BATCH_SIZE=5
AI_POST_BATCH_MAX_TOKENS=2600

# AI question cards (contextual societal asks)
QUESTION_BRIEFS_MODEL=gpt-5-nano
QUESTION_BRIEFS_MAX_TOKENS=2600
QUESTION_BRIEFS_TRIAGE_MODEL=gpt-5-nano
QUESTION_BRIEFS_TRIAGE_MAX_TOKENS=1400
QUESTION_BRIEFS_USE_AI_TRIAGE=false
QUESTION_BRIEFS_SYNTHESIS_MODEL=gpt-5-nano
QUESTION_BRIEFS_SYNTHESIS_MAX_TOKENS=2200
QUESTION_BRIEFS_CACHE_TTL_SECONDS=7200
QUESTION_BRIEFS_WINDOW_DAYS=30
QUESTION_BRIEFS_MAX_TOPICS=14
QUESTION_BRIEFS_MAX_BRIEFS=8
QUESTION_BRIEFS_EVIDENCE_PER_TOPIC=14
QUESTION_BRIEFS_MIN_CONFIDENCE=0.60
QUESTION_BRIEFS_MESSAGE_CHAR_LIMIT=900
QUESTION_BRIEFS_CONTEXT_CHAR_LIMIT=520
QUESTION_BRIEFS_SYNTH_EVIDENCE_LIMIT=8
QUESTION_BRIEFS_CLUSTER_SIMILARITY=0.42
QUESTION_BRIEFS_MIN_CLUSTER_MESSAGES=8
QUESTION_BRIEFS_MIN_CLUSTER_USERS=3
QUESTION_BRIEFS_MIN_CLUSTER_CHANNELS=2
QUESTION_BRIEFS_MAX_CLUSTER_CANDIDATES=24
QUESTION_BRIEFS_MIN_ACCEPTED_CLUSTERS=6
QUESTION_BRIEFS_REFRESH_MINUTES=120
QUESTION_BRIEFS_REFRESH_ON_STARTUP=true
QUESTION_BRIEFS_PROMPT_VERSION=qcards-v2

# Behavioral briefs (AI-generated behavioral insights)
BEHAVIORAL_BRIEFS_MODEL=gpt-5-nano
BEHAVIORAL_BRIEFS_MAX_TOKENS=1500
BEHAVIORAL_BRIEFS_CACHE_TTL_SECONDS=7200
BEHAVIORAL_BRIEFS_WINDOW_DAYS=30
BEHAVIORAL_BRIEFS_MIN_MESSAGES=10
BEHAVIORAL_BRIEFS_MIN_USERS=3
BEHAVIORAL_BRIEFS_MAX_BRIEFS=8
BEHAVIORAL_BRIEFS_REFRESH_MINUTES=120
BEHAVIORAL_BRIEFS_REFRESH_ON_STARTUP=true
BEHAVIORAL_BRIEFS_PROMPT_VERSION=behavior-v2

# Additional processing configuration
AI_MESSAGE_CHAR_LIMIT=800
TAXONOMY_VERSION=v2
STRICT_TAXONOMY_PROMPT=true
SCRAPE_BACKPRESSURE_UNPROCESSED_POSTS=500
SCRAPE_BACKPRESSURE_UNPROCESSED_COMMENTS=2000
